{
  "name": "retail-visibility-platform",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "apps/api/dist/index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "doppler run --config dev -- pnpm -r --parallel dev",
    "dev:local": "doppler run --config local -- pnpm -r --parallel dev",
    "dev:vercel": "doppler run --config local -- vercel --force",
    "dev:vercel-local": "doppler run --config local -- vercel dev --debug",
    "dev:local-vercel": "doppler run --config local -- pnpm -r --parallel --filter @rvp/web dev:vercel-web --filter @rvp/api dev:vercel-api",
    "dev:prod": "doppler run --config prd -- pnpm -r --parallel dev",
    "test:cache": "node run-cache-test.js",
    "test:cache:ts": "npx tsx run-cache-test.ts",
    "build": "pnpm -r build",
    "start": "cd apps/api && npm start",
    "buildweb": "cd apps/web && pnpm build",
    "dev:vercel-api": "cd apps/api && doppler run --config local -- pnpm -r --parallel dev",
    "dev:vercel-web": "doppler run --config local -- vercel dev --debug",
    "buildapi": "cd apps/api && pnpm build",
    "buildmain": "pnpm build",
    "checkapi-type": "npx tsc --noEmit -p apps/api/tsconfig.json 2>&1",
    "checkapi": "npx tsc --noEmit --project apps/api 2>&1",
    "checkweb": "npx tsc --noEmit --project apps/web 2>&1",
    "prisma:generate": "npm run -w @rvp/api prisma:generate",
    "typecheck": "pnpm -r typecheck || exit 0",
    "lint": "pnpm -r lint || exit 0",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.26.0",
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.16.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.1",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@types/uuid": "^10.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "glob": "^13.0.0",
    "lucide-react": "^0.546.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "react-hook-form": "^7.70.0",
    "require-in-the-middle": "^8.0.1",
    "square": "^43.2.0",
    "tailwind-merge": "^3.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "overrides": {
    "form-data": "^4.0.1",
    "tough-cookie": "^4.1.4",
    "@prisma/client": "^6.19.1",
    "prisma": "^6.19.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.19.3"
  }
}
