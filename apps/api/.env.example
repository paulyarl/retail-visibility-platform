# API env example
API_PORT=4000

# Database — Local dev (SQLite)
# DATABASE_URL="file:./prisma/dev.db"

# Database — Supabase pooler (PgBouncer/Supavisor)
# Port 6543 = pooler (for app queries), Port 5432 = direct (for migrations)
# pgbouncer=true is REQUIRED for Prisma to work through the Supabase pooler
# connection_limit=5 keeps Prisma's pool small to avoid exhausting Supabase connections
# DATABASE_URL="postgresql://postgres.[project]:[password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"
# DIRECT_URL="postgresql://postgres.[project]:[password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Email Configuration
EMAIL_PROVIDER=mailtrap  # Options: sendgrid, ses, mailtrap, console
EMAIL_FALLBACK_PROVIDERS=sendgrid,ses,console  # Comma-separated fallback order
EMAIL_FROM=noreply@visibleshelf.store
EMAIL_FROM_NAME=Your Platform

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@visibleshelf.store
SENDGRID_FROM_NAME=Your Platform

# AWS SES Configuration  
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SES_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SES_FROM_EMAIL=noreply@visibleshelf.store
AWS_SES_FROM_NAME=Your Platform

# Mailtrap Configuration (for testing)
MAILTRAP_TOKEN=your_mailtrap_token
MAILTRAP_ACCOUNT_ID=your_mailtrap_account_id
MAILTRAP_INBOX_ID=your_mailtrap_inbox_id
MAILTRAP_FROM_EMAIL=noreply@visibleshelf.store
MAILTRAP_FROM_NAME=Your Platform

# Square POS Integration
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_ENVIRONMENT=sandbox  # or 'production'
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key
SQUARE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/square/callback

# Logging & Observability
LOG_LEVEL=info                    # debug | info | warn | error
LOG_DIR=./logs                    # File log directory (production only)
LOG_DB_ENABLED=false              # Set to 'true' to force-enable DB error logging in dev
LOG_RETENTION_DAYS=30             # File log retention (days) — used by purge job
SENTRY_DSN=                       # Sentry error tracking DSN (leave empty to disable)
SENTRY_ENVIRONMENT=               # Sentry environment label (defaults to NODE_ENV)
SENTRY_API_TOKEN=                 # Sentry API token for admin monitoring dashboard
SENTRY_ORG_SLUG=                  # Sentry organization slug for admin dashboard
NEW_RELIC_LICENSE_KEY=            # New Relic APM license key (production only)
NEW_RELIC_APP_NAME=VisibleShelf API
