generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model account_deletion_requests {
  id                      String?
  user_id                 String?
  reason                  String?
  status                  String?
  requested_at            DateTime? @db.Timestamptz(6)
  scheduled_deletion_date DateTime? @db.Timestamptz(6)
  cancelled_at            DateTime? @db.Timestamptz(6)
  completed_at            DateTime? @db.Timestamptz(6)
  ip_address              String?
  admin_notes             String?
  cancelled_by_admin      Boolean?
  preserve_data           Boolean?
  created_at              DateTime? @db.Timestamptz(6)
  updated_at              DateTime? @db.Timestamptz(6)

  @@index([requested_at(sort: Desc)], map: "idx_account_deletion_requests_requested_at")
  @@index([scheduled_deletion_date], map: "idx_account_deletion_requests_scheduled_deletion_date")
  @@index([status], map: "idx_account_deletion_requests_status")
  @@index([user_id], map: "idx_account_deletion_requests_user_id")
  @@ignore
}

model audit_log {
  id           String      @id
  tenant_id    String
  actor_id     String
  actor_type   actor_type
  diff         Json
  entity_id    String
  entity_type  entity_type
  ip           String?
  metadata     Json        @default("{}")
  occurred_at  DateTime    @default(now())
  pii_scrubbed Boolean     @default(true)
  request_id   String?
  user_agent   String?
  action       action

  @@index([tenant_id, occurred_at(sort: Desc)], map: "audit_log_tenant_id_occurred_at_sort_desc_idx")
}

model barcode_enrichment {
  id                  String   @id
  barcode             String   @unique
  name                String?
  brand               String?
  description         String?
  category_path       String[]
  price_cents         Int?
  image_url           String?
  image_thumbnail_url String?
  metadata            Json?
  source              String
  last_fetched_at     DateTime @default(now())
  fetch_count         Int      @default(1)
  created_at          DateTime @default(now())
  updated_at          DateTime
}

model barcode_lookup_log {
  id         String   @id
  tenant_id  String
  barcode    String
  provider   String?
  status     String   @default("success")
  response   Json?
  latency_ms Int?
  error      String?
  created_at DateTime @default(now())
}

model business_hours_list {
  id             String    @id
  tenant_id      String    @unique
  timezone       String    @default("America/New_York")
  periods        Json      @default("[]")
  source_hash    String?
  last_synced_at DateTime?
  sync_attempts  Int       @default(0)
  last_error     String?
  created_at     DateTime  @default(now())
  updated_at     DateTime
  tenants        tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}

model business_hours_special_list {
  id             String    @id
  tenant_id      String
  date           DateTime  @db.Date
  isClosed       Boolean   @default(false)
  open           String?
  close          String?
  note           String?
  source_hash    String?
  last_synced_at DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime
  tenants        tenants   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, date])
  @@index([tenant_id, date])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model capability_features_list {
  id                   String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  capability_type_id   String
  feature_id           String
  restrictions         Json?
  is_active            Boolean?             @default(true)
  sort_order           Int?                 @default(0)
  created_at           DateTime?            @default(now()) @db.Timestamp(6)
  updated_at           DateTime?            @default(now()) @db.Timestamp(6)
  capability_type_list capability_type_list @relation(fields: [capability_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  features_list        features_list        @relation(fields: [feature_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([capability_type_id, feature_id])
  @@index([feature_id], map: "idx_capability_features_list_feature_id")
  @@index([capability_type_id], map: "idx_capability_features_list_type_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model capability_type_list {
  id                       String                     @id @default(dbgenerated("(gen_random_uuid())::text"))
  key                      String                     @unique
  name                     String
  description              String?
  category                 String?
  tier_id                  String?
  is_active                Boolean?                   @default(true)
  sort_order               Int?                       @default(0)
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  capability_features_list capability_features_list[]
  subscription_tiers_list  subscription_tiers_list?   @relation(fields: [tier_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tier_features_list       tier_features_list[]

  @@index([category], map: "idx_capability_type_list_category")
  @@index([key], map: "idx_capability_type_list_key")
  @@index([tier_id], map: "idx_capability_type_list_tier_id")
