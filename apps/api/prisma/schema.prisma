model category_mirror_runs {
  id           String    @id
  tenant_id    String?
  strategy     String
  dry_run      Boolean   @default(true)
  created      Int       @default(0)
  updated      Int       @default(0)
  deleted      Int       @default(0)
  skipped      Boolean   @default(false)
  reason       String?
  error        String?
  job_id       String?
